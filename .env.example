# Database (SQLite للتطوير - بسيط ولا يحتاج إعداد)
DATABASE_URL="file:./prisma/dev.db"

# للإنتاج استخدم PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/quran_db"

# NextAuth — مهم!
NEXTAUTH_URL="http://localhost:3000"
# في الإنتاج: غيّرها لرابط موقعك مثل https://yoursite.com
NEXTAUTH_SECRET="ضع-سراً-عشوائياً-طويلاً-هنا-32-حرف-على-الأقل"
# لتوليد سر آمن: openssl rand -base64 32

# Google OAuth (اختياري - لتسجيل الدخول بـ Google)
# الحصول عليها من: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Site URL للـ SEO
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
