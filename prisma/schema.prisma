// منصة القرآن الكريم - Database Schema
// نستخدم SQLite للتطوير (يمكن التحويل لـ PostgreSQL بسهولة في الإنتاج)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============== NextAuth.js Models ==============

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== App Models ==============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  bookmarks    Bookmark[]
  notes        Note[]
  readingLog   ReadingLog[]
  preferences  UserPreference?
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  surah     Int
  verse     Int
  text      String
  reference String
  color     String?  @default("gold")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, surah, verse])
  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  surah     Int
  verse     Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([surah, verse])
}

model ReadingLog {
  id        String   @id @default(cuid())
  userId    String
  surah     Int
  verse     Int?
  duration  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("light")
  fontFamily      String   @default("amiri")
  fontSize        Float    @default(1.7)
  reciter         String   @default("Alafasy_128kbps")
  defaultTafsir   String   @default("ar.muyassar")
  defaultTrans    String   @default("en.sahih")
  showTranslation Boolean  @default(false)
  readMode        String   @default("page")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
